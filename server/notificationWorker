const { 
    getPendingNotifications, 
    markAsQueued, 
    markAsSent,
    markAsRead 
} = require("./notificationQueue");

// ── Configuration ──
const CONFIG = {
    MAX_RETRIES: 3,
    BATCH_SIZE: 50,
    WORKER_INTERVAL: 30000, // 30 seconds
};

